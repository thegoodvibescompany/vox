# =====================================================================
# VOX — Beispiel-Umgebungsvariablen. Kopieren nach .env.local und ausfüllen.
# =====================================================================
# Die App spricht ausschließlich serverseitig mit Supabase (SSR-only). Solange
# die server-only Namen (ohne NEXT_PUBLIC_) gesetzt sind, landet keine dieser
# Variablen im Browser-Bundle.

# ── Supabase-Verbindung (Pflicht) ─────────────────────────────────────────
# URL des Supabase-Projekts bzw. des self-hosted Gateways (Kong).
SUPABASE_URL=http://127.0.0.1:54321
# "Publishable"/anon-Key. NIEMALS den service_role-Key hier eintragen —
# die App kommt vollständig ohne service_role aus (RLS ist die Schutzschicht).
SUPABASE_PUBLISHABLE_KEY=
# Alternativ funktionieren die NEXT_PUBLIC_-Varianten (Fallback für lokale
# Setups). Auf Produktiv-Instanzen die server-only Namen oben bevorzugen.

# ── Öffentliche App-URL (Pflicht in Produktion) ───────────────────────────
# Basis für Magic-Link-Redirects. Schlägt client-kontrollierbare Host-Header
# (Härtung). Lokal: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Fachstellen-Mailversand (SMTP) ────────────────────────────────────────
# Provider-agnostisches Relay (eigener Postfix, Smarthost, Resend-SMTP …).
# Ohne HOST + MAIL_FROM wird nichts versendet; die App meldet dann einen
# Konfigurationsfehler. Betrifft NICHT die Auth-Mails (Magic-Link) — die
# verschickt der Supabase-Auth-Dienst (GoTrue) über seine eigene SMTP-Konfig.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
